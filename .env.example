# OpenAI (required for production Vision listing engine)
OPENAI_API_KEY=sk-...

# Supabase (required for production auth + listings DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: service role for server-side image uploads during publish
SUPABASE_SERVICE_ROLE_KEY=
# Public storage bucket for listing photos (required for Vinted/Whatnot data-URL photos)
SUPABASE_STORAGE_BUCKET=listing-images

# Set to "true" to force demo auth even when Supabase is configured
NEXT_PUBLIC_DEMO_AUTH=false

# App URL used for OAuth redirects and staged image hosting
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encrypts marketplace connection tokens in httpOnly cookies (min 16 chars)
CONNECTIONS_SECRET=replace-with-long-random-secret

# --- eBay Sell Inventory (OAuth + publish) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# RuName / redirect_uri value from eBay Developer Portal
EBAY_RU_NAME=
EBAY_ENV=sandbox
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_MERCHANT_LOCATION_KEY=
# Optional clothing default category
EBAY_DEFAULT_CATEGORY_ID=15724

# --- Vinted Pro Integrations ---
# Official docs: https://pro-docs.svc.vinted.com/
# Requires Vinted Pro + Integrations allowlist approval.
VINTED_PRO_BASE_URL=https://pro.svc.vinted.com
# CreateItems Currency enum is EUR|GBP only
VINTED_CURRENCY=EUR

# --- Whatnot Seller API (OAuth + GraphQL) ---
# Official docs: https://developers.whatnot.com/docs/getting-started/introduction
# Developer Preview — Whatnot is not accepting new applicants at this time.
WHATNOT_CLIENT_ID=
WHATNOT_CLIENT_SECRET=
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/marketplaces/whatnot/oauth/callback
WHATNOT_REDIRECT_URI=
WHATNOT_ENV=stage
# Optional override for ProductCategoryInput.categoryId
# Taxonomy: https://api.whatnot.com/seller-api/rest/product-taxonomy/US.txt
WHATNOT_DEFAULT_CATEGORY_ID=