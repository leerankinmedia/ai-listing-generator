# Supabase (required for production auth + listings DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (AI listing generation via Vision)
OPENAI_API_KEY=sk-...

# Set to "true" to force demo auth even when Supabase is configured
NEXT_PUBLIC_DEMO_AUTH=false
