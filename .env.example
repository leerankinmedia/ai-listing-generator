# ListWise — Phase 1 environment
# Copy to .env.local and fill in values for production auth.

# Supabase (required for real authentication)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (used in future AI listing generation phases)
OPENAI_API_KEY=

# Without Supabase vars, ListWise runs in demo auth mode
# so you can explore the UI (login/signup → dashboard).
