# =============================================================================
# ListWise environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# --- OpenAI (required for Vision listing engine) ---
OPENAI_API_KEY=sk-...

# --- Supabase (required for production auth + cloud persistence) ---
# Dashboard → Project Settings → API
#   Project URL          → NEXT_PUBLIC_SUPABASE_URL
#   Publishable key      → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   Secret / service_role → SUPABASE_SERVICE_ROLE_KEY (server only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Secret key — required for marketplace photo uploads during publish.
# Never expose this in client-side code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key
# Must match the storage bucket created by migration 003 (listing-images)
SUPABASE_STORAGE_BUCKET=listing-images

# Force demo auth even when Supabase is configured (keep false in production)
NEXT_PUBLIC_DEMO_AUTH=false

# Public app URL (OAuth redirects + optional staged media)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encrypts marketplace connection tokens (min 16 chars). Required for Connections.
CONNECTIONS_SECRET=replace-with-long-random-secret

# --- Stripe billing (TEST MODE only until you go live) ---
# Dashboard → Developers → API keys (use sk_test_… / publishable pk_test_…)
STRIPE_SECRET_KEY=sk_test_...
# Recurring monthly Price ID from Products (price_…)
STRIPE_PRICE_ID=price_...
# Webhook signing secret from Developers → Webhooks (whsec_…)
STRIPE_WEBHOOK_SECRET=whsec_...
# Display label only (actual charge comes from STRIPE_PRICE_ID)
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_LABEL=$29/month
# Keep false while verifying test mode. Set true + redeploy to enforce access.
BILLING_ENFORCEMENT=false

# --- eBay Sell Inventory (OAuth + publish) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
EBAY_ENV=sandbox
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_MERCHANT_LOCATION_KEY=
EBAY_DEFAULT_CATEGORY_ID=15724

# --- Vinted Pro Integrations ---
VINTED_PRO_BASE_URL=https://pro.svc.vinted.com
VINTED_CURRENCY=EUR

# --- Whatnot Seller API ---
WHATNOT_CLIENT_ID=
WHATNOT_CLIENT_SECRET=
WHATNOT_REDIRECT_URI=
WHATNOT_ENV=stage
WHATNOT_DEFAULT_CATEGORY_ID=
